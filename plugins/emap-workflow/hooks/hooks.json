{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash emap-workflow/hooks/scripts/validate-branch.sh",
            "statusMessage": "Validating branch naming convention..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash emap-workflow/hooks/scripts/enforce-review.sh",
            "statusMessage": "Tracking changes for review..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash emap-workflow/hooks/scripts/session-summary.sh",
            "statusMessage": "Generating session summary..."
          }
        ]
      }
    ]
  }
}

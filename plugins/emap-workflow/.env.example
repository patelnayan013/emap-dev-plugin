# EMAP Workflow Plugin - Environment Variables
# Copy this file to .env and fill in your values
# DO NOT commit .env to git

# Linear API Key
# Get it from: linear.app → Settings → API → Create key
LINEAR_API_KEY=

# Slack Webhook URL
# Get it from: api.slack.com/apps → Your App → Incoming Webhooks
EMAP_SLACK_WEBHOOK_URL=
